# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files — always LF in repo
*.tsx        text eol=lf
*.ts         text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.jsx        text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.html       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.env        text eol=lf
*.gitignore  text eol=lf

# Binary files — no conversion
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.pdf        binary
*.mp4        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
